{
  "name": "ferma-tolk-mobile",
  "version": "1.0.0",
  "type": "module",
  "description": "Mobile-first Ferma.Tolk app powered by Capacitor + React + Supabase",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "vite",
    "start": "npm run dev",
    "build": "vite build",
    "preview": "vite preview",
    "test": "node --env-file=.env.test --test src/lib/*.test.js src/features/**/*.test.js api/*.test.js",
    "test:e2e": "playwright test",
    "validate:env": "node scripts/validate-env.js",
    "validate:migrations": "node scripts/validate-migrations.js",
    "smoke-test": "node scripts/smoke-test.js",
    "lint": "eslint src api scripts",
    "lint:fix": "eslint src api scripts --fix",
    "format": "prettier --write .",
    "mobile:build": "npm run build && npx cap sync",
    "mobile:sync": "npx cap sync",
    "mobile:add:android": "npx cap add android",
    "mobile:add:ios": "npx cap add ios",
    "mobile:open:android": "npx cap open android",
    "mobile:open:ios": "npx cap open ios",
    "mobile:run:android": "npx cap run android",
    "mobile:run:ios": "npx cap run ios",
    "mobile:android:debug:apk": "bash scripts/mobile/android-build-debug.sh"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.4.3",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^15.15.0",
    "prettier": "^3.8.1",
    "supabase": "^2.91.2",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "@capacitor/android": "^7.4.3",
    "@capacitor/app": "^7.0.3",
    "@capacitor/core": "^7.4.3",
    "@capacitor/ios": "^7.4.3",
    "@capacitor/keyboard": "^7.0.3",
    "@capacitor/status-bar": "^7.0.3",
    "@supabase/supabase-js": "^2.101.1",
    "@tanstack/react-query": "^5.96.2",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "supabase-cli": "^0.0.21",
    "zod": "^4.3.6"
  }
}
