# =============================================================================
# Ferma.Tolk — Environment Variables Reference
# =============================================================================
# Copy this file to .env.local for local development:
#   cp .env.example .env.local
#
# NEVER commit .env, .env.local, .env.development.local, .env.production, or
# any file containing real credentials to source control.
#
# For secret rotation procedures, see docs/SECRETS-MANAGEMENT.md.
#
# Variable classification:
#   [BROWSER]  — included in the Vite bundle (VITE_ prefix); safe to expose
#   [SERVER]   — only read by Vercel Edge Functions via process.env; never bundled
#   [OPTIONAL] — has a default; missing value produces a warning, not a failure
# =============================================================================

# -----------------------------------------------------------------------------
# SUPABASE — Browser client (public, safe to expose)
# [BROWSER] Required
# -----------------------------------------------------------------------------
# Used by: src/lib/config.js → src/lib/supabase.js
# These values are visible in the browser bundle. That is intentional — they
# grant only the access that Row-Level Security policies allow.
# Get from: Supabase Dashboard → Settings → API → Project URL / anon key
#
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# -----------------------------------------------------------------------------
# SUPABASE — Server-side (secret, never bundled)
# [SERVER] Required
# -----------------------------------------------------------------------------
# Used by: api/_config.js → api/_auth-session.js, api/_supabase-admin.js
#
# IMPORTANT: Edge Functions use process.env at *request time*. They cannot
# read Vite build-time substitutions. You must set SUPABASE_URL as a plain
# Vercel env var in addition to VITE_SUPABASE_URL (same value, different name).
#
# Set in Vercel → Settings → Environment Variables (Production + Preview + Development)
# See docs/SECRETS-MANAGEMENT.md for rotation instructions.
#
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Database connection string for migrations and admin scripts.
# Append ?sslmode=require for all non-local environments.
# Get from: Supabase Dashboard → Settings → Database → URI tab
#
SUPABASE_DB_URL=postgresql://postgres:[YOUR-PASSWORD]@db.your-project-ref.supabase.co:5432/postgres?sslmode=require

# -----------------------------------------------------------------------------
# DEEPGRAM — Speech-to-Text (secret, never bundled)
# [SERVER] Required for voice input
# -----------------------------------------------------------------------------
# Used by: api/_config.js → api/speech.js
# Get from: https://console.deepgram.com → API Keys → Create a key
# Scope required: usage:write
#
DEEPGRAM_API_KEY=your-deepgram-api-key-here

# -----------------------------------------------------------------------------
# APP — Runtime configuration
# -----------------------------------------------------------------------------

# [BROWSER] Required — controls fail-fast behaviour and probe logging
# Set to: local | development | staging | production
VITE_APP_ENV=local

# [SERVER] Optional — restricts CORS on the speech endpoint
# Set to your production domain, e.g. https://ferma.tolk.app
# If absent, all *.vercel.app preview URLs are allowed (acceptable for development)
APP_ORIGIN=

# -----------------------------------------------------------------------------
# RATE LIMITING — Tuneable defaults for speech endpoint abuse protection
# [SERVER] Optional — all have safe defaults defined in api/_config.js
# -----------------------------------------------------------------------------
# Increase for high-traffic farms; decrease to tighten abuse protection.
# See api/_rate-limiter.js for the algorithm details.
#
# RATE_IP_MAX=30       # max requests per IP per minute (default: 30)
# RATE_USER_MAX=10     # max requests per user per minute (default: 10)
# RATE_BURST_MAX=5     # max requests per user per 3 seconds (default: 5)
# RATE_DAILY_MAX=200   # max requests per user per calendar day (default: 200)
